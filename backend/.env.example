GROQ_API_KEY=your_groq_api_key_here
PORT=8788

# Required in production. Comma-separated list of frontend origins allowed to connect (both
# REST and Socket.io) — e.g. your deployed Vercel URL. Leave unset for local dev only; an
# unset value falls back to allowing any origin, which is fine on localhost but must be set
# before this is reachable from the public internet.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional. Leave unset and chat history is kept in-memory only (lost on server restart).
# Set to enable real persistence across restarts — your OWN personal MongoDB Atlas cluster.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
# MONGODB_DB_NAME=aslchat

# Optional. Leave unset to run in open mode (free-text display name, manual room codes,
# no real accounts). Set both to require Clerk sign-in and enable GET /api/users/search —
# the frontend also needs the matching VITE_CLERK_PUBLISHABLE_KEY, see frontend/.env.example.
# CLERK_SECRET_KEY=your_clerk_secret_key_here
# CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Optional. Leave unset and "Hear this message" is unavailable (button hidden). Used only
# for reading messages aloud — never for mic/dictation input, which stays on the browser's
# built-in Web Speech API.
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional. Leave both unset and the daily ASL lesson broadcast is disabled. Set both to
# enable POST /api/telegram/send-lesson (Clerk-gated, heavily rate-limited — this posts into
# YOUR OWN Telegram channel, not a per-user feature). Create a bot via @BotFather to get a
# token; TELEGRAM_CHANNEL_ID is the numeric chat/channel ID to post into.
# TELEGRAM_ACCESS_TOKEN=your_bot_token_here
# TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# Optional. Leave unset and the daily lesson is only sendable manually via the API above.
# Set to an HH:MM (24-hour, server-local time) to also auto-send once a day.
# TELEGRAM_DAILY_LESSON_TIME=09:00
