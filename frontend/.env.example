VITE_API_URL=http://localhost:8788

# Optional. Leave unset to run in open mode (free-text display name, no real accounts).
# Set to require Clerk sign-in — must match the CLERK_PUBLISHABLE_KEY in backend/.env
# (same Clerk application, publishable half of the key pair).
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
